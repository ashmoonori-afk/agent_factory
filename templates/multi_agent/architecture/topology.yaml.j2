# Multi-Agent Topology — {{ name }}
# Generated by Agent Factory

name: {{ name }}
type: multi
{%- if spec.get("topology") %}
topology:
  entry: {{ spec.topology.get("entry", "") }}
  max_loops: {{ spec.topology.get("max_loops", 3) }}
  exit_condition: {{ spec.topology.get("exit_condition", "all agents complete") }}
{%- endif %}
{%- if spec.get("agents") %}
agents:
{%- for agent in spec.agents %}
  - id: {{ agent.id }}
    role: {{ agent.role }}
{%- if agent.get("next") %}
    next:
{%- for n in agent.next %}
      - {{ n }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}

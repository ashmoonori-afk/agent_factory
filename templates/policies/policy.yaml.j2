# Policy Rules — {{ name }}
# Generated by Agent Factory
#
# DENY: NEVER execute. No override. No exceptions.
# ASK: Confirm with user before every execution.
# ALLOW: Execute freely.

{%- if spec.get("policies") and spec.policies.get("deny") %}
deny:
{%- for action in spec.policies.deny %}
  - "{{ action }}"
{%- endfor %}
{%- else %}
deny: []
{%- endif %}

{%- if spec.get("policies") and spec.policies.get("ask") %}
ask:
{%- for action in spec.policies.ask %}
  - "{{ action }}"
{%- endfor %}
{%- else %}
ask: []
{%- endif %}

{%- if spec.get("policies") and spec.policies.get("allow") %}
allow:
{%- for action in spec.policies.allow %}
  - "{{ action }}"
{%- endfor %}
{%- else %}
allow:
  - "*"
{%- endif %}

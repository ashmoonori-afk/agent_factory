# Agent Specification — {{ name }}
# Generated by Agent Factory

name: {{ name }}
description: {{ description }}
type: {{ type }}
{%- if spec.get("runtime") %}
runtime:
  primary: {{ spec.runtime.get("primary", "both") }}
{%- endif %}
{%- if spec.get("policies") %}
policies:
{%- if spec.policies.get("deny") %}
  deny:
{%- for action in spec.policies.deny %}
    - "{{ action }}"
{%- endfor %}
{%- endif %}
{%- if spec.policies.get("ask") %}
  ask:
{%- for action in spec.policies.ask %}
    - "{{ action }}"
{%- endfor %}
{%- endif %}
{%- if spec.policies.get("allow") %}
  allow:
{%- for action in spec.policies.allow %}
    - "{{ action }}"
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if persona %}
persona:
{%- if persona.get("tone") %}
  tone: {{ persona.tone }}
{%- endif %}
{%- if persona.get("language") %}
  language: {{ persona.language }}
{%- endif %}
{%- endif %}
{%- if skills | length > 0 %}
skills:
{%- for skill in skills %}
  - {{ skill }}
{%- endfor %}
{%- endif %}
